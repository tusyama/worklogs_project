MONGO_APP_USER=worklog
MONGO_APP_PASSWORD=worklog
# Docker network hostnames (compose). For host-run API (`npm run dev:api`): use 127.0.0.1 instead of mongo/redis.
MONGODB_URI=mongodb://worklog:worklog@mongo:27017/worklog?authSource=worklog
REDIS_URL=redis://redis:6379
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost
VITE_API_URL=/api

# Dev stack by default: mongo + redis + Vite :5173 + API watch (see docker-compose.yml profile `dev`)
COMPOSE_PROFILES=dev
